# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# ملاحظة: public/data (حزمة القوانين ~54MB) تُرفَع للمستودع عمداً
# لأنّ بناء GitHub Pages السحابي يحتاجها (قاعدة laws.db المصدرية مستثناة ومحلية فقط).

# production
/build

# بيانات المكتبة المحلية (قاعدة البيانات + النماذج المُنزَّلة + ملفات تلجرام)
/data

# مصادر خام للفهرسة (HTML/تحليلات) — محلية فقط، تُدرَج في قاعدة البيانات ولا تُرفَع
/imports

# مجموعة Nexus المُصدَّرة (تُولَّد من laws.db عبر scripts/nexus-export.mjs)
/nexus-corpus

# بيئة بايثون وجلسة تلجرام (تحتوي بيانات دخول حساسة)
/scripts/.venv
/scripts/*.session
/scripts/*.session-journal

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# حالة أدوات Claude Code المحلية
/.claude

# مواد مصدرية محلية لا تُنشَر (تطبيق Flutter المصدر + APK + ملفّ الكشف PDF)
/التطبيق
*.apk
/*.pdf

# بناء أندرويد ومفتاح التوقيع (حسّاس جداً — لا يُنشَر أبداً)
/android-build
*.keystore
*.jks

# مخرجات بناء APK (الملفات + توقيعاتها) — لا تُحفَظ في git
/dist

# مواد بحثية/مصدرية محلية غير متعلّقة بكود التطبيق
/دراسات سابقة
*.docx

# ملفّ نشر Actions: معطَّل مؤقتاً (يحتاج صلاحية workflow على التوكن)؛
# النشر الحالي عبر فرع gh-pages. لتفعيل النشر التلقائي: امنح الصلاحية وأزِل هذا السطر.
/.github/workflows/deploy.yml
public/models/
public/ort/
